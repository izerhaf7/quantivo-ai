# Copy to .env (gitignored) and fill in real values. Never commit real keys.
# One shared .env at the repo root -- ml/, backend/, and scraping/ all load
# it from here explicitly (see ml/llm_demo.py's ROOT_ENV, scraping/__init__.py's
# stray-.env warning). Don't create a second .env inside a subdirectory.

# ── ml/ — LLM + embeddings (Fireworks AI, runs on AMD MI300X/MI350) ─────────
# Get a key via the AMD AI Developer Program (includes $50 Fireworks credit),
# see spesifikasi-teknis-boa-saas.md for context.
FIREWORKS_API_KEY=
# Optional overrides -- Fireworks' catalog moves; re-check
# GET /inference/v1/models before changing these. Defaults match
# backend/orchestrator.py's built-in fallback if left unset.
# FIREWORKS_SMALL_MODEL=accounts/fireworks/models/gpt-oss-120b
# FIREWORKS_LARGE_MODEL=accounts/fireworks/models/deepseek-v4-pro
# FIREWORKS_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# ── scraping/ — real scraper modules (all 9 degrade gracefully to 0 items
# if their key is missing -- circuit breaker, not a crash). ─────────────────
GOOGLE_PLACES_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
BPS_API_KEY=
# Not self-serve -- see scraping/README.md. Safe to leave empty; the
# Databoks module just contributes 0 items + a degradation note.
DATABOKS_API_KEY=
# Powers 3 modules: TikTok, Instagram, X (BrightData Datasets v3).
BRIGHTDATA_API_KEY=
SOCIALAPIS_API_KEY=

# ── backend/ — job store + real-pipeline wiring ─────────────────────────────
REDIS_URL=redis://localhost:6379
# CORS_ORIGINS=http://localhost:3000
# Real Qdrant instance for QdrantRetriever (docker/deploy/docker-compose.yml
# brings one up on this default port).
QDRANT_URL=http://localhost:6333
# Escape hatch: skip all of the above and run the fully-offline
# fixture/Mock* pipeline (same wiring ml/run_demo.py uses) -- no API keys or
# external services needed. Default is real wiring; set true only for local
# dev without keys/services.
# USE_MOCKS=false

# ── frontend/ — real backend wiring (Vite env, not read by Python) ─────────
# Empty/unset = same-origin (works behind the nginx proxy in production and
# via vite.config.ts's dev proxy locally). Only set this if the frontend and
# backend are served from different origins.
# VITE_API_BASE_URL=
